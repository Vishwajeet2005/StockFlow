# ── StockFlow Backend Environment ───────────────────────────────────────────
# Copy this file to .env before running: cp .env.example .env

# Server port
PORT=3001

# IMPORTANT: Change these secrets before deploying to production!
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=dev_jwt_secret_change_in_production_32chars
REFRESH_SECRET=dev_refresh_secret_change_in_production_32chars

# Path to SQLite database file
DB_PATH=./data/inventory.db

# Frontend URL for CORS (change in production)
FRONTEND_URL=http://localhost:5173

# Environment
NODE_ENV=development
