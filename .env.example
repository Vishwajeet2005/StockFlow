# ── Docker Deployment Secrets ────────────────────────────────────────────────
# The deploy.sh script auto-generates these. Or set them manually:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
REFRESH_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# Port to expose on the host (default: 80)
PORT=80

# Your domain/IP for CORS
FRONTEND_URL=http://localhost
